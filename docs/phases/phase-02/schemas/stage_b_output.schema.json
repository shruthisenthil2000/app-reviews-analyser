{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://groww-pulse.local/schemas/stage_b_output.schema.json",
  "title": "Groq Stage B — weekly pulse output",
  "type": "object",
  "required": ["pulse_body", "quotes", "actions"],
  "additionalProperties": false,
  "properties": {
    "pulse_body": { "type": "string", "minLength": 50, "maxLength": 4000 },
    "quotes": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["text", "review_ids"],
        "additionalProperties": false,
        "properties": {
          "text": { "type": "string", "minLength": 5, "maxLength": 500 },
          "review_ids": {
            "type": "array",
            "minItems": 1,
            "maxItems": 5,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "actions": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["title", "rationale"],
        "additionalProperties": false,
        "properties": {
          "title": { "type": "string", "minLength": 5, "maxLength": 120 },
          "rationale": { "type": "string", "minLength": 10, "maxLength": 400 }
        }
      }
    }
  }
}

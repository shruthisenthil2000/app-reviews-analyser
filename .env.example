# Copy to .env and fill in values (never commit .env)
#   cp .env.example .env

# Groq — required for Phase 3 LLM calls (https://console.groq.com/keys)
GROQ_API_KEY=

# Optional pipeline tuning (defaults match docs/phases/phase-02/stage-0-spec.md)
SAMPLER_SEED=42
# Use 280–350 for Groq free tier (100k TPD); 1000 is the hard ceiling
SAMPLE_MAX_REVIEWS=280
STAGE_A_TEXT_MAX_CHARS=320

# Phase 4 MCP delivery (Saksham server — see docs/phases/phase-04/mcp-saksham-server.md)
MCP_SERVER_URL=https://saksham-mcp-server-production-f2a5.up.railway.app
MCP_API_KEY=
# Gmail draft recipient (required for Phase 4 Gmail delivery)
PULSE_TO_EMAIL=your.name@gmail.com

# Google Doc ID to append each weekly pulse (optional)
GOOGLE_DOC_ID=

